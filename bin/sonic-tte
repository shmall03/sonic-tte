#!/bin/bash

# Sonic-TTE: High-Impact Animated Media Screensaver
# ------------------------------------------------
# Monitors music playback and displays animated ASCII art titles.
# Created for the Omarchy & Arch + Hyprland communities.
# License: GPLv3

# --- 1. Pre-flight Dependency Check ---
# Ensures all required tools are available before starting.
for cmd in playerctl figlet python3; do
    if ! command -v "$cmd" &> /dev/null; then
        echo "Error: '$cmd' is not installed. Please install it to use Sonic-TTE." >&2
        exit 1
    fi
done

# Check for TerminalTextEffects (tte or terminaltexteffects)
if command -v tte &> /dev/null; then
    TTE_CMD="tte"
elif command -v terminaltexteffects &> /dev/null; then
    TTE_CMD="terminaltexteffects"
else
    echo "Error: 'TerminalTextEffects' (tte) is not installed. Please install it to use Sonic-TTE." >&2
    exit 1
fi

# Functional check for TTE
if ! "$TTE_CMD" --version &> /dev/null; then
    echo "Error: '$TTE_CMD' was found but is not responding to --version. Check your installation." >&2
    exit 1
fi

# --- 2. Load Paths & Configuration ---
BIN_DIR=$(dirname "$(readlink -f "$0")")

# Support both local/dev and system paths.
if [ -f "$BIN_DIR/../share/fonts/Delta-Corps-Priest-1.flf" ]; then
    SHARE_DIR="$BIN_DIR/../share"
else
    SHARE_DIR="/usr/share/sonic-tte"
fi

if [ -f "$BIN_DIR/center_text.py" ]; then
    CENTER_TEXT="$BIN_DIR/center_text.py"
else
    CENTER_TEXT="$SHARE_DIR/center_text.py"
fi
DEFAULT_FONT="$SHARE_DIR/fonts/Delta-Corps-Priest-1.flf"

# Set defaults
FONT_PATH="$DEFAULT_FONT"
OUTPUT_FILE="/tmp/sonic-tte-$(id -u).txt" # User-specific to avoid multi-user conflicts
WRAP_WIDTH=20
POLL_INTERVAL=2
INCLUDE_EFFECTS=""
EXCLUDE_EFFECTS=""
PLAYER="" # Default to all players

# Secure Parser: Only loads specific allowed keys
load_config() {
    local conf="$1"
    [ -f "$conf" ] || return
    while IFS='=' read -r key value; do
        # Clean whitespace and skip comments/empty lines
        key=$(echo "$key" | xargs)
        [[ "$key" =~ ^#.*$ ]] && continue
        [[ -z "$key" ]] && continue
        
        # Strip quotes and leading/trailing whitespace from value
        value=$(echo "$value" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' -e 's/^["'\'']//' -e 's/["'\'']$//')

        # Allow only a specific set of keys
        case "$key" in
            FONT_PATH|OUTPUT_FILE|WRAP_WIDTH|POLL_INTERVAL|INCLUDE_EFFECTS|EXCLUDE_EFFECTS|PLAYER)
                printf -v "$key" "%s" "$value"
                ;;
        esac
    done < "$conf"
}

# XDG Standard: Check User Config, then Global, then Local fallback.
USER_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/sonic-tte/config"
GLOBAL_CONF="/etc/sonic-tte/config"
LOCAL_CONF="$SHARE_DIR/sonic-tte.conf.example"

if [ -f "$USER_CONF" ]; then
    load_config "$USER_CONF"
elif [ -f "$GLOBAL_CONF" ]; then
    load_config "$GLOBAL_CONF"
elif [ -f "$LOCAL_CONF" ]; then
    load_config "$LOCAL_CONF"
fi

# Font Height Detection
if [ -f "$FONT_PATH" ]; then
    FONT_HEIGHT=$(head -n 1 "$FONT_PATH" | awk '{print $2}')
fi
# Validate FONT_HEIGHT is a positive integer, fallback to 9
[[ "$FONT_HEIGHT" =~ ^[0-9]+$ ]] || FONT_HEIGHT=9

TTE_PID=0
MONITOR_PID=0

# --- 3. Core Functions ---

# Generates ASCII art from the current song title.
generate_ascii() {
    local title="$1"
    
    # If no title, clear the file and exit to trigger the idle sleep in the main loop.
    if [ -z "$title" ]; then
        : > "$OUTPUT_FILE"
        return
    fi
    
    # Convert to uppercase (bash built-in)
    title="${title^^}"
    
    # fmt: wraps text to the configured width.
    # figlet: generates the ASCII art blocks.
    # "$CENTER_TEXT": handles complex terminal centering logic.
    echo "$title" | fmt -w "$WRAP_WIDTH" | \
        figlet -f "$FONT_PATH" -w 1000 | \
        "$CENTER_TEXT" "$FONT_HEIGHT" > "$OUTPUT_FILE.tmp"
    
    # Atomic move to prevent 'tte' from reading a partial file.
    mv "$OUTPUT_FILE.tmp" "$OUTPUT_FILE"
}

# Handles song changes by killing the current animation to start a new one.
handle_change() {
    [ "$TTE_PID" -ne 0 ] && kill "$TTE_PID" 2>/dev/null
}
trap handle_change USR1

# Handles terminal resize by killing the current animation (forces restart with new COLS/LINES)
handle_resize() {
    [ "$TTE_PID" -ne 0 ] && kill "$TTE_PID" 2>/dev/null
}
trap handle_resize WINCH

# Graceful shutdown: cleans up background processes and restores terminal state.
cleanup() {
    trap - SIGINT SIGTERM EXIT # Disable traps to prevent recursion
    echo -e "\nShutting down Sonic-TTE..."
    [ "$TTE_PID" -ne 0 ] && kill "$TTE_PID" 2>/dev/null
    [ "$MONITOR_PID" -ne 0 ] && kill "$MONITOR_PID" 2>/dev/null
    pkill -P $$ 2>/dev/null
    stty echo    # Restore terminal input visibility
    exit 0
}
# Safety net: Broad EXIT trap ensures we restore terminal even on unexpected exit.
trap cleanup SIGINT SIGTERM EXIT

# --- 4. Background Media Monitor ---
(
    # Playerctl arguments: target specific player if configured
    PLAYER_ARGS=()
    [ -n "$PLAYER" ] && PLAYER_ARGS=("-p" "$PLAYER")

    # Initial generation
    generate_ascii "$(playerctl "${PLAYER_ARGS[@]}" metadata title 2>/dev/null)"
    kill -USR1 $$
    
    # Event-driven monitor: waits for playerctl to report a title change.
    playerctl "${PLAYER_ARGS[@]}" metadata --follow title 2>/dev/null | while IFS='' read -r title; do
        generate_ascii "$title"
        kill -USR1 $$
    done
) &
MONITOR_PID=$!

# --- 5. Foreground Display & Input Loop ---
echo "Sonic-TTE is active. Monitoring playerctl..."
echo "Keys: [SPACE] Skip Effect | [Q] Quit"

# stty -echo hides the keypresses from the terminal while the screensaver runs.
stty -echo

while true; do
    # 5a. Start a new effect if one isn't currently running.
    if [ "$TTE_PID" -eq 0 ] && grep -q "[^[:space:]]" "$OUTPUT_FILE" 2>/dev/null; then
        COLS=$(tput cols)
        LINES=$(tput lines)
        
        # Build TerminalTextEffects arguments array for safer handling.
        TTE_ARGS=(
            "--input-file" "$OUTPUT_FILE"
            "--random-effect"
            "--canvas-width" "$COLS"
            "--canvas-height" "$LINES"
            "--anchor-text" "c"
            "--reuse-canvas"
            "--no-eol"
        )
        [ -n "$INCLUDE_EFFECTS" ] && TTE_ARGS+=("--include-effects" "$INCLUDE_EFFECTS")
        [ -n "$EXCLUDE_EFFECTS" ] && TTE_ARGS+=("--exclude-effects" "$EXCLUDE_EFFECTS")

        "$TTE_CMD" "${TTE_ARGS[@]}" &
        TTE_PID=$!
    fi

    # 5b. Keybind handling (non-blocking read).
    # We check for input every 0.2 seconds.
    if IFS='' read -r -t 0.2 -n 1 key; then
        case "$key" in
            " ") # SPACE: Skip the current effect.
                [ "$TTE_PID" -ne 0 ] && kill "$TTE_PID" 2>/dev/null
                ;;
            "q"|"Q") # Q: Exit the program.
                exit 0
                ;;
        esac
    fi

    # 5c. Housekeeping: check if the tte process has finished naturally.
    if [ "$TTE_PID" -ne 0 ] && ! kill -0 "$TTE_PID" 2>/dev/null; then
        TTE_PID=0
    fi
    
    # 5d. Idle behavior: if no music is playing, sleep to save CPU.
    if [ "$TTE_PID" -eq 0 ] && ! grep -q "[^[:space:]]" "$OUTPUT_FILE" 2>/dev/null; then
        sleep "$POLL_INTERVAL"
    fi
done
